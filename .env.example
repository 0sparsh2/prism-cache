# Copy to .env and fill in values:
#   cp .env.example .env
#
# Load before starting LiteLLM:
#   set -a && source .env && set +a
#
# .env is gitignored — never commit real keys.

# LiteLLM proxy auth — you choose this string (not issued by LiteLLM or any provider).
# Clients send: Authorization: Bearer $LITELLM_MASTER_KEY
LITELLM_MASTER_KEY=sk-prism-local-dev

# --- gateway/litellm.prism.yaml (OpenAI + Anthropic) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- gateway/litellm.nim.yaml (NVIDIA NIM) ---
# Get a key at https://build.nvidia.com — LiteLLM expects NVIDIA_NIM_API_KEY (not NVIDIA_API_KEY).
NVIDIA_NIM_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1

# --- gateway/litellm.gemini.yaml (Google AI Studio) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-your-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=gemini-embed
LITELLM_BASE_URL=http://localhost:4000
# When Gemini free tier hits daily limit (~20 req/day), use NIM for chat instead:
# PRISM_CHAT_MODEL=deepseek-v4-flash

# Production Redis (Tier 1/2/3 persistence)
REDIS_URL=redis://localhost:6379/0

# Phase F — vLLM + LMCache (GPU host only)
# HF_TOKEN=hf_...
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
